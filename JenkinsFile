pipeline {
    agent any

    stages {
        stage('Clone') {
            steps {
                echo 'Source code downloaded from GitHub'
            }
        }

        stage('Build') {
            steps {
                echo'Buiding project'
            }
        }

        stage('Test') {
            steps {
                echo 'Running unit tests...'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploy successful!'
            }
        }
    }
}
